# ── VMIXSOCIAL もどき 環境変数サンプル ──
# ローカルで使うときは「.env」にコピーせず、コマンドで指定してもOK:
#   APP_PASSWORD=yourpass PORT=8080 npm start
# PaaS では各サービスのダッシュボードで設定します（.env はコミットしない）。

# 操作画面のログインパスワード。
# 公開デプロイ時は必ず設定（未設定だと誰でも操作できてしまう）。
APP_PASSWORD=change-me

# 出力画面(/output)とWebSocketもトークン必須にしたい場合のみ設定（任意・完全非公開化）。
# 設定すると vMix に入れるURLは  https://<host>/output?token=<ここの値>  になります。
OUTPUT_TOKEN=

# ログインCookieの署名用シークレット（未設定なら自動。PaaSでは自動生成推奨）。
SESSION_SECRET=

# データ(queue.json)と画像(media/)の保存先。
# PaaSで永続ボリュームをマウントした場合にそのパスを指定（例: /var/data）。
# 未設定ならプロジェクト内 ./data に保存。
DATA_DIR=

# 待受ポート。PaaSは自動で割り当てるため通常は未設定でOK。
# ローカルで3000が埋まっている場合などに指定。
PORT=3000
