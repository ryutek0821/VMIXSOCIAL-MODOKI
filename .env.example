# ── VMIXSOCIAL もどき 環境変数サンプル（マルチテナント版）──
# ローカルで使うときは「.env」にコピーせず、コマンドで指定してもOK:
#   ADMIN_PASSWORD=yourpass PORT=8080 npm start
# PaaS では各サービスのダッシュボードで設定します（.env はコミットしない）。

# 管理画面(/admin)の管理者パスワード。
# ここから「サービス（ID＋パスワード）」を追加/削除します。
# 未設定の場合は初回起動時に自動生成され、コンソールに表示されます（必ず控えてください）。
ADMIN_PASSWORD=change-me-admin

# ── 以下は「旧・単一テナント運用」からの移行用（任意・新規構築なら不要）──
# APP_PASSWORD を設定して起動すると、その値をパスワードに持つ "default" サービスが
# 自動作成されます（既存の data/queue.json があれば default サービスへ引き継ぎ）。
# 新規にマルチテナントで使う場合は未設定のままにし、管理画面からサービスを作成してください。
APP_PASSWORD=

# 旧 OUTPUT_TOKEN は移行時に "default" サービスの出力トークンとして引き継がれます（任意）。
# 新規サービスの出力トークンはサービス作成時に自動発行されます。
OUTPUT_TOKEN=

# ログインCookieの署名用シークレット（未設定なら自動。PaaSでは自動生成推奨）。
SESSION_SECRET=

# データ(accounts.json / services/<id>/queue.json)と画像(media/)の保存先。
# PaaSで永続ボリュームをマウントした場合にそのパスを指定（例: /var/data）。
# 未設定ならプロジェクト内 ./data に保存。
DATA_DIR=

# 待受ポート。PaaSは自動で割り当てるため通常は未設定でOK。
# ローカルで3000が埋まっている場合などに指定。
PORT=3000
